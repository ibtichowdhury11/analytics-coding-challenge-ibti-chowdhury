# Lightdash
PGHOST=lightdash-db
PGPORT=5432
PGUSER=lightdash
PGPASSWORD=lightdash
PGDATABASE=lightdash
LIGHTDASH_SECRET=change-me-to-a-real-secret
LIGHTDASH_PORT=8880
SITE_URL=http://localhost:8880
S3_REGION=us-east-1
S3_BUCKET=lightdash
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
ALLOW_MULTIPLE_ORGS=false

# Lightdash Admin (auto-created on first run)
ADMIN_EMAIL=admin@lightdash.com
ADMIN_PASSWORD=admin123!


